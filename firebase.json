{
  "functions": {
    "source": ".",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "vscode-extension",
      "context",
      "dashboard",
      "contextlens-dashboard"
    ]
  },
  "firestore": [
    {
      "database": "default",
      "rules": "firestore.rules"
    }
  ],
  "hosting": {
    "public": "contextlens-dashboard/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/auth/**",
        "function": "authService"
      },
      {
        "source": "/api/calls/log",
        "function": "aiService"
      },
      {
        "source": "/api/episodes/explain",
        "function": "aiService"
      },
      {
        "source": "/api/branches/summarize",
        "function": "aiService"
      },
      {
        "source": "/api/**",
        "function": "coreService"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Cross-Origin-Opener-Policy",
            "value": "same-origin-allow-popups"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "Permissions-Policy",
            "value": "camera=(), microphone=(), geolocation=()"
          }
        ]
      },
      {
        "source": "assets/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ]
  },
  "auth": {
    "providers": {
      "emailPassword": true,
      "googleSignIn": {
        "oAuthBrandDisplayName": "ContextLens",
        "supportEmail": "shasarita23@gmail.com"
      }
    }
  }
}
