// -------------------------------------------------------
// AUTO CREATE EPISODE
// Called by watchers automatically — no user input needed
// -------------------------------------------------------
async autoCreateEpisode(
  label: string,
  branchName?: string
): Promise<void> {
  // Close current episode if one is active
  if (this.state.episodeId) {
    try {
      await this.closeEpisode();
    } catch (err) {
      // Continue even if close fails
    }
  }

  // Use provided branch or detect it
  const branch = branchName || this.state.branchName || 'main';

  // Create the new episode automatically
  try {
    const result = await this.api.post('/episodes/create', {
      projectId: this.state.projectId,
      label: label,
      branchName: branch,
    });

    this.state.episodeId = result.episodeId;
    this.state.episodeLabel = label;
    this.state.callCount = 0;
    this.state.changedFiles = [];
    this.state.branchName = branch;

    // Persist to globalState
    await this.context.globalState.update(
      'contextlens.episodeId', result.episodeId
    );
    await this.context.globalState.update(
      'contextlens.episodeLabel', label
    );
    await this.context.globalState.update(
      'contextlens.branchName', branch
    );
    await this.context.globalState.update(
      'contextlens.callCount', 0
    );
    await this.context.globalState.update(
      'contextlens.changedFiles', []
    );

  } catch (err: any) {
    // Silent fail — don't show error for auto operations
  }
}

