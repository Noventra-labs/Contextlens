import * as vscode from 'vscode';
import * as fs from 'fs';
import * as path from 'path';
import { captureGitContext } from './gitContext';

// -------------------------------------------------------
// TYPES
// -------------------------------------------------------

interface WatcherDeps {
  context: vscode.ExtensionContext;
  episodeStore: any;
  apiClient: any;
  stateTreeProvider: any;
  statusBar: any;
}

// -------------------------------------------------------
// MAIN WATCHER ENTRY POINT
// Call this from activate() in extension.ts
// -------------------------------------------------------

export async function startWatchers(deps: WatcherDeps): Promise<void> {
  const { context } = deps;
  const workspaceRoot = vscode.workspace.workspaceFolders?.[0]?.uri.fsPath;
  if (!workspaceRoot) return;

  const gitDir = path.join(workspaceRoot, '.git');
  if (!fs.existsSync(gitDir)) {
    // Not a git repo — watch for when it becomes one
    watchForGitInit(workspaceRoot, deps);
    return;
  }

  // Start all watchers
  watchBranchChanges(gitDir, deps);
  watchCommits(gitDir, deps);
  watchFileSaves(deps);
  watchWorkspaceFolderChanges(deps);
  startTokenRefresh(deps);
  autoInitEpisode(deps);
}

// -------------------------------------------------------
// WATCHER 1 — BRANCH CHANGES
// Watches .git/HEAD for branch switches
// Auto-creates a new episode when branch changes
// -------------------------------------------------------

let lastBranch: string | null = null;
const branchWatchers: fs.FSWatcher[] = [];

function watchBranchChanges(gitDir: string, deps: WatcherDeps): void {
  const { episodeStore, stateTreeProvider, statusBar } = deps;
  const headFile = path.join(gitDir, 'HEAD');

  if (!fs.existsSync(headFile)) return;

  const watcher = fs.watch(headFile, async () => {
    try {
      const git = await captureGitContext();
      const newBranch = git.branchName;

      if (!lastBranch) {
        lastBranch = newBranch;
        return;
      }

      if (newBranch !== lastBranch && newBranch !== 'HEAD') {
        const previousBranch = lastBranch;
        lastBranch = newBranch;

        // Close current episode for old branch
        const state = episodeStore.getState();
        if (state.episodeId) {
          await episodeStore.closeEpisode();
        }

        // Auto-create new episode for new branch
        await episodeStore.autoCreateEpisode(
          `${newBranch}`,
          newBranch
        );

        stateTreeProvider.refresh();
        statusBar.render();

        vscode.window.showInformationMessage(
          `ContextLens: Switched to branch "${newBranch}" — new episode started automatically.`
        );
      }
    } catch (err) {
      // Silent fail — never interrupt the developer
    }
  });

  branchWatchers.push(watcher);

  // Store disposable
  deps.context.subscriptions.push({
    dispose: () => {
      watcher.close();
    }
  });
}

// -------------------------------------------------------
// WATCHER 2 — GIT COMMITS
// Watches .git/COMMIT_EDITMSG
// Every commit is auto-logged as a call in the episode
// -------------------------------------------------------

let lastCommitMessage: string | null = null;

function watchCommits(gitDir: string, deps: WatcherDeps): void {
  const { episodeStore, apiClient, stateTreeProvider, statusBar } = deps;
  const commitFile = path.join(gitDir, 'COMMIT_EDITMSG');

  if (!fs.existsSync(commitFile)) return;

  // Read initial commit message to avoid false trigger on startup
  try {
    lastCommitMessage = fs.readFileSync(commitFile, 'utf8').trim();
  } catch {
    lastCommitMessage = '';
  }

  const watcher = fs.watch(commitFile, async () => {
    try {
      await new Promise(resolve => setTimeout(resolve, 300)); // debounce

      const raw = fs.readFileSync(commitFile, 'utf8').trim();

      // Ignore comment lines and unchanged messages
      const message = raw
        .split('\n')
        .filter(l => !l.startsWith('#'))
        .join('\n')
        .trim();

      if (!message || message === lastCommitMessage) return;
      lastCommitMessage = message;

      const state = episodeStore.getState();
      if (!state.projectId || !state.episodeId) return;

      const git = await captureGitContext();

      // Log commit as a call in the current episode
      await apiClient.logCall({
        projectId: state.projectId,
        episodeId: state.episodeId,
        promptText: `git commit: ${message}`,
        modelResponse: 'Commit recorded by ContextLens',
        source: 'git_commit',
        modelName: 'git',
        intentTag: message,
        branchName: git.branchName,
        activeFilePath: '',
        relatedFiles: git.relatedFiles,
        diffSnapshot: git.diffSnapshot,
        todoMatches: git.todoMatches,
      });

      stateTreeProvider.refresh();
      statusBar.render();

    } catch (err) {
      // Silent fail
    }
  });

  deps.context.subscriptions.push({
    dispose: () => watcher.close()
  });
}

// -------------------------------------------------------
// WATCHER 3 — FILE SAVES
// Every meaningful file save updates the episode's
// changed files list silently
// -------------------------------------------------------

function watchFileSaves(deps: WatcherDeps): void {
  const { context, episodeStore, stateTreeProvider } = deps;
  const workspaceRoot = vscode.workspace.workspaceFolders?.[0]?.uri.fsPath;

  context.subscriptions.push(
    vscode.workspace.onDidSaveTextDocument(async (doc) => {
      try {
        const state = episodeStore.getState();
        if (!state.episodeId) return;
        if (!workspaceRoot) return;
        if (!doc.uri.fsPath.startsWith(workspaceRoot)) return;

        // Skip node_modules, .git, dist, build
        const skipPatterns = [
          'node_modules', '.git', 'dist', 'build',
          '.next', 'out', '.cache', '__pycache__'
        ];
        if (skipPatterns.some(p => doc.uri.fsPath.includes(p))) return;

        // Only track code files
        const codeExtensions = [
          '.ts', '.tsx', '.js', '.jsx', '.py', '.go',
          '.java', '.kt', '.swift', '.rs', '.c', '.cpp',
          '.cs', '.php', '.rb', '.dart', '.vue', '.svelte'
        ];
        const ext = path.extname(doc.uri.fsPath);
        if (!codeExtensions.includes(ext)) return;

        // Add to changed files list
        await episodeStore.addChangedFile(doc.uri.fsPath);
        stateTreeProvider.refresh();

      } catch (err) {
        // Silent fail
      }
    })
  );
}

// -------------------------------------------------------
// WATCHER 4 — WORKSPACE FOLDER CHANGES
// When developer opens a new folder, auto-detect project
// -------------------------------------------------------

function watchWorkspaceFolderChanges(deps: WatcherDeps): void {
  const { context, episodeStore, stateTreeProvider, statusBar } = deps;

  context.subscriptions.push(
    vscode.workspace.onDidChangeWorkspaceFolders(async (event) => {
      if (event.added.length > 0) {
        await episodeStore.ensureProject(context);
        await autoInitEpisode(deps);
        stateTreeProvider.refresh();
        statusBar.render();
      }
    })
  );
}

// -------------------------------------------------------
// WATCHER 5 — WATCH FOR GIT INIT
// If folder is not yet a git repo, watch for git init
// -------------------------------------------------------

function watchForGitInit(workspaceRoot: string, deps: WatcherDeps): void {
  const { context } = deps;

  const watcher = fs.watch(workspaceRoot, async (event, filename) => {
    if (filename === '.git') {
      const gitDir = path.join(workspaceRoot, '.git');
      if (fs.existsSync(gitDir)) {
        watcher.close();
        // Git repo initialized — start all watchers
        await startWatchers(deps);
      }
    }
  });

  context.subscriptions.push({
    dispose: () => watcher.close()
  });
}

// -------------------------------------------------------
// AUTO INIT — Create episode automatically on startup
// if no active episode exists
// -------------------------------------------------------

export async function autoInitEpisode(deps: WatcherDeps): Promise<void> {
  const { episodeStore } = deps;

  try {
    const state = episodeStore.getState();

    // Already have an active episode — nothing to do
    if (state.episodeId && state.episodeLabel) {
      lastBranch = state.branchName;
      return;
    }

    // No project yet — nothing to do
    if (!state.projectId) return;

    // Capture current branch and auto-create episode
    const git = await captureGitContext();
    lastBranch = git.branchName;

    await episodeStore.autoCreateEpisode(
      `${git.branchName}`,
      git.branchName
    );

  } catch (err) {
    // Silent fail
  }
}

// -------------------------------------------------------
// TOKEN AUTO-REFRESH
// Silently refreshes Firebase ID token every 50 minutes
// Firebase ID tokens expire after 60 minutes
// -------------------------------------------------------

function startTokenRefresh(deps: WatcherDeps): void {
  const { context } = deps;

  // Refresh every 50 minutes (tokens expire at 60 min)
  const REFRESH_INTERVAL = 50 * 60 * 1000;

  const intervalId = setInterval(async () => {
    try {
      await refreshFirebaseToken(context);
    } catch (err) {
      // Silent fail — next API call will handle auth error
    }
  }, REFRESH_INTERVAL);

  context.subscriptions.push({
    dispose: () => clearInterval(intervalId)
  });
}

async function refreshFirebaseToken(
  context: vscode.ExtensionContext
): Promise<void> {
  const refreshToken = await context.secrets.get('contextlens.refreshToken');
  const apiKey = 'YOUR_FIREBASE_API_KEY'; // same key used in apiClient.ts

  if (!refreshToken) return;

  const res = await fetch(
    `https://securetoken.googleapis.com/v1/token?key=${apiKey}`,
    {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: `grant_type=refresh_token&refresh_token=${refreshToken}`,
    }
  );

  if (!res.ok) return;

  const data = await res.json() as any;

  if (data.id_token) {
    await context.secrets.store('contextlens.token', data.id_token);
  }
  if (data.refresh_token) {
    await context.secrets.store('contextlens.refreshToken', data.refresh_token);
  }
}
