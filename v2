// ADD CHANGED FILE
// Called by file save watcher automatically
// -------------------------------------------------------
async addChangedFile(absolutePath: string): Promise<void> {
  const workspaceRoot =
    vscode.workspace.workspaceFolders?.[0]?.uri.fsPath || '';

  // Convert to relative path
  const relativePath = absolutePath
    .replace(workspaceRoot, '')
    .replace(/^\//, '')
    .replace(/^\\/, '');

  // Don't add duplicates
  if (this.state.changedFiles.includes(relativePath)) return;

  this.state.changedFiles.push(relativePath);

  await this.context.globalState.update(
    'contextlens.changedFiles',
    this.state.changedFiles
  );
}

