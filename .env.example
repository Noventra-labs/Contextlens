# ContextLens Backend Environment Variables
# Copy this file to .env and fill in your values.

# ── Required ────────────────────────────────────────────────────────────────

# Google Cloud project ID (auto-set by Firebase CLI in deployment)
GOOGLE_CLOUD_PROJECT=contextlens-backend-001

# Firebase client config (used to render the sign-in page)
CLIENT_FIREBASE_API_KEY=your-firebase-api-key
CLIENT_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
CLIENT_FIREBASE_PROJECT_ID=your-project-id

# ── Optional ────────────────────────────────────────────────────────────────

# Vertex AI configuration
# VERTEX_LOCATION=us-central1
# VERTEX_MODEL=gemini-1.5-pro
# VERTEX_TIMEOUT_MS=30000
# VERTEX_RETRY_ATTEMPTS=2
# USE_VERTEX=true

# CORS allowed origins (comma-separated)
# ALLOWED_ORIGINS=https://contextlens-backend-001.web.app,http://localhost:5173

# AES-256-GCM key for encrypting API keys at rest (64 hex chars = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SETTINGS_ENCRYPTION_KEY=

# Sentry DSN for error tracking
# SENTRY_DSN=

# Node environment
# NODE_ENV=production
